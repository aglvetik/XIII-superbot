# XIII Superbot safe example env.
# No real secrets are included.
# Numeric Discord IDs below are sample snowflakes for local staging only.
# Replace placeholder IDs/tokens and verify every path against the real VPS before deployment.
# Keep all *_ENABLED flags false until cutover verification is complete.

# Discord core
# DISCORD_TOKEN must be the bot token for the same application as DISCORD_CLIENT_ID.
DISCORD_TOKEN=<discord_bot_token>
# DISCORD_CLIENT_ID must be the Discord application / bot client ID.
DISCORD_CLIENT_ID=1501644078012694558
XIII_GUILD_ID=1498022112114249819
# Optional guild-scoped command sync target for explicit sync-commands runs.
DISCORD_COMMAND_SYNC_GUILD_ID=1498022112114249819
DISCORD_SYNC_COMMANDS_ON_STARTUP=false

# Module enable flags: keep mutating modules disabled until their cutover.
TICKETS_ENABLED=false
VOICE_ACTIVITY_ENABLED=false
RECRUIT_ENABLED=false
VACATION_ENABLED=false
DISCIPLINE_ENABLED=false
CLANLIST_ENABLED=false
TEMP_VOICE_ENABLED=false

# Superbot runtime gates
# Production examples below use /opt/XIII/xiii-superbot. Keep these paths private in
# .env.production on the VPS; use .env.local for local validation.
SUPERBOT_STATE_DIR=/opt/XIII/xiii-superbot/data
SUPERBOT_REQUIRE_OLD_SERVICES_STOPPED=true
SUPERBOT_ALLOW_LEGACY_DB_WRITES=false
SUPERBOT_HEALTH_OUTPUT=/opt/XIII/xiii-superbot/data/superbot_health.json

# Guild/global IDs
XIII_MEMBER_ROLE_ID=1498022112114249827
XIII_GUEST_ROLE_ID=1498022112114249825
XIII_RECRUIT_ROLE_ID=1498022112114249828
XIII_NEXT_RANK_ROLE_ID=1498022112131289208
XIII_OFFICER_ROLE_IDS=1498022112131289216,1498022112131289217
XIII_INTERVIEWER_ROLE_ID=1498057076151422976

# Ticket module
# Message Content intent must be enabled before real ticket cutover because
# legacy text commands (!panel / !accept / !принять / !reject / !отклонить) are supported.
TICKET_PANEL_CHANNEL_ID=1498081266568921152
TICKET_OPEN_CATEGORY_ID=1498793152646086656
TICKET_TRANSCRIPT_CHANNEL_ID=1498088262483316817
TICKET_OFFICER_REVIEW_CHANNEL_ID=1500136438791147651
TICKET_SUPPORT_ROLE_ID=1498057076151422976
TICKET_GLOBAL_MODERATOR_ROLE_IDS=1498091840899911690,1498022112131289217,1498022112131289216
TICKET_CUSTOM_COMMAND_ROLE_IDS=1498022112131289216,1498022112131289217
TICKET_APPLICATION_PING_ROLE_ID=1498057076151422976
TICKET_OTHER_PING_ROLE_ID=1498057076151422976
TICKET_IDEA_PING_ROLE_ID=1498091840899911690
TICKET_ACCEPT_ROLE_IDS=1498022112114249828,1498022112114249827
TICKET_GOOGLE_CREDENTIALS_FILE=<path_to_ticket_service_account_json>
TICKET_GOOGLE_SHEET_ID=<ticket_google_sheet_id>
TICKET_GOOGLE_SHEET_NAME=<ticket_google_worksheet_name>
TICKET_GOOGLE_POLL_SECONDS=30

# Voice activity module
VOICE_STATS_PANEL_CHANNEL_ID=1500963695327707236
VOICE_INACTIVE_COMMAND_CHANNEL_ID=1499669325685198888
VOICE_AUTO_REPORT_CHANNEL_ID=1499770822938722354
VOICE_INACTIVE_ROLE_ID=1498022112114249827
VOICE_VACATION_MARKER_ROLE_ID=1498113605768314921
VOICE_IGNORED_CHANNEL_IDS=1498022116682104914
VOICE_HEARTBEAT_INTERVAL_SECONDS=60
VOICE_PUBLIC_STATS_UPDATE_INTERVAL_SECONDS=60
VOICE_AUTO_REPORT_CHECK_INTERVAL_SECONDS=600
VOICE_AUTO_REPORT_SEND_ON_FIRST_START=false
VOICE_PUBLIC_STATS_PANEL_ENABLED=true
VOICE_AUTO_REPORTS_ENABLED=true
VOICE_PAGE_SIZE=10
VOICE_ENABLE_PREFIX_COMMANDS=false
VOICE_COMMAND_PREFIX=!

# Recruit module
RECRUIT_DECISION_CHANNEL_ID=1500136438791147651
RECRUIT_DECISION_PING_ROLE_IDS=1498091840899911690,1498057076151422976
RECRUIT_EXCLUDED_VOICE_CHANNEL_ID=1498022116682104914
RECRUIT_DEFAULT_DAYS=14
RECRUIT_CHECK_INTERVAL_SECONDS=300

# Vacation module
VACATION_PANEL_CHANNEL_ID=1500437958375903232
VACATION_OFFICER_CHANNEL_ID=1500438001514184714
VACATION_ACTIVE_PANEL_CHANNEL_ID=1501256029399285810
VACATION_ROLE_ID=1498022112131289214
VACATION_OFFICER_PING_ROLE_ID=1498091840899911690
VACATION_MAX_DAYS=100
VACATION_BRAND_NAME=XIII

# Discipline module
DISCIPLINE_BOARD_CHANNEL_ID=1501216257859649646
DISCIPLINE_LOG_CHANNEL_ID=1501216301191004363
DISCIPLINE_MAIN_CLAN_ROLE_ID=1498022112114249827
DISCIPLINE_COMPOSITION_ROLE_IDS=1498022112114249827,1498022112131289208,1498022112131289209,1498022112114249828
DISCIPLINE_TIMEOUT_MINUTES=45
DISCIPLINE_WARNING_EXPIRES_DAYS=7
DISCIPLINE_VERBAL_EXPIRES_DAYS=14
DISCIPLINE_BOARD_REFRESH_SECONDS=60
DISCIPLINE_LOG_EXPIRATIONS=false

# Clanlist module
CLANLIST_MAIN_CHANNEL_ID=1498762828666896535
CLANLIST_ADMIN_CHANNEL_ID=1498763049102868672
CLANLIST_STEAM_CHANNEL_ID=1500081418506862754
CLANLIST_MAIN_ROLE_IDS=1498022112131289217,1498022112131289216,1498022112131289215,1498022112131289209,1498022112131289208,1498022112114249828
CLANLIST_ADMIN_ROLE_IDS=1498022112131289217,1498057076151422976,1498091840899911690,1498091694456049994
CLANLIST_STEAM_ACTIVE_ROLE_ID=1498022112114249827
CLANLIST_UPDATE_DEBOUNCE_SECONDS=5
CLANLIST_AUTO_REFRESH_SECONDS=600
CLANLIST_BOOTSTRAP_SCAN_LIMIT=2000
CLANLIST_EDIT_SLEEP_SECONDS=0.55
CLANLIST_SEND_SLEEP_SECONDS=0.85
CLANLIST_GOOGLE_SERVICE_ACCOUNT_FILE=<path_to_clanlist_service_account_json>
CLANLIST_GOOGLE_SHEET_ID=<clanlist_google_sheet_id>
CLANLIST_GOOGLE_WORKSHEET_NAME=
CLANLIST_GOOGLE_FETCH_MIN_INTERVAL_SECONDS=60
CLANLIST_GOOGLE_STEAM_ID_COLUMN=D
CLANLIST_GOOGLE_DISCORD_ID_COLUMN=E

# Temp voice module
TEMP_VOICE_DELETE_AFTER_SECONDS=0

# Legacy state paths for compatibility mode.
# These are production-style Linux examples only. Use .env.local for local validation paths and
# replace these with the current VPS legacy DB/state locations before real cutover.
LEGACY_TICKET_DB_PATH=/opt/xiii-ticketbot/tickets.db
LEGACY_VOICE_DB_PATH=/opt/XIII/xiii-voice-activity-bot/data/voice_activity.sqlite3
LEGACY_RECRUIT_DB_PATH=/opt/XIII/xiii-recruit-bot/data/recruits.db
LEGACY_VACATION_DB_PATH=/opt/XIII/xiii-vacation-bot/data/vacations.db
LEGACY_DISCIPLINE_DB_PATH=/opt/XIII/xiii-discipline-bot/data/discipline.sqlite
LEGACY_TEMP_VOICE_DB_PATH=/opt/XIII/temp-voice-bot/data/bot.sqlite3
LEGACY_CLANLIST_DATA_DIR=/opt/XIII/XIII-clanlist/data

# Future unified DB. Do not enable writes until the DB strategy is implemented.
DATABASE_URL=sqlite:/opt/XIII/xiii-superbot/data/xiii_superbot.sqlite3

# Runtime
TIMEZONE=Europe/Berlin
LOG_LEVEL=info
